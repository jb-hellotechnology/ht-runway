# Perch Runway
RewriteEngine On

# Serve the XML sitemap (generated by sitemap.php) at /sitemap.xml
RewriteRule ^sitemap\.xml$ /sitemap.php [L]

# Redirect old /articles/ URLs to /blog/ (permanent)
RewriteRule ^articles/(.*)$ /blog/$1 [R=301,L]

RewriteCond %{REQUEST_URI} !^/admin
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule .* /admin/core/runway/start.php [L]

# ----------------------------------------------------------------------
# Browser caching for static assets (LiteSpeed honours mod_expires)
# ----------------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  # Images & fonts rarely change — cache hard
  ExpiresByType image/jpeg             "access plus 1 year"
  ExpiresByType image/png              "access plus 1 year"
  ExpiresByType image/gif              "access plus 1 year"
  ExpiresByType image/webp             "access plus 1 year"
  ExpiresByType image/svg+xml          "access plus 1 year"
  ExpiresByType image/x-icon           "access plus 1 year"
  ExpiresByType font/woff2             "access plus 1 year"
  ExpiresByType font/woff              "access plus 1 year"
  # CSS/JS — shorter, since /styles.css has no version string (see note)
  ExpiresByType text/css               "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
</IfModule>

# ----------------------------------------------------------------------
# Compression (LiteSpeed usually does this itself; harmless if so)
# ----------------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript \
    application/javascript application/json image/svg+xml application/xml
</IfModule> 